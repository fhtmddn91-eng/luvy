# Copy to .env and fill in. Never commit real secrets.

# PostgreSQL connection string.
# Local dev example (Homebrew postgres): postgresql://USER@localhost:5432/luvy_dev?schema=public
# On Railway: use the Postgres plugin's DATABASE_URL reference variable.
DATABASE_URL="postgresql://user:password@host:5432/luvy?schema=public"

# Session signing key — REQUIRED in production (app refuses to start without it).
# Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-secret"

# NHN KCP via PortOne V2.
# Leave empty to keep the mock checkout (order is "received" without real payment).
# Set ALL FOUR to enable real payments (create a PortOne store + KCP test channel).
PORTONE_STORE_ID=""          # 콘솔 > 상점 식별코드 (store-...)
PORTONE_CHANNEL_KEY_KCP=""   # 콘솔 > 결제연동 > 채널관리 (KCP 채널의 channel-key-...)
PORTONE_API_SECRET=""        # 콘솔 > API Keys > V2 API Secret (서버 전용)
PORTONE_WEBHOOK_SECRET=""    # 콘솔 > 웹훅 > 시크릿
